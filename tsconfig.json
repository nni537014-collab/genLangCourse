{
  "compilerOptions": {
    "target": "ES2024",
    "lib": [
      "ES2024",
      "ESNext.Collection"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    // Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    // Ecosystem
    "allowImportingTsExtensions": true,
    "moduleDetection": "force"
  },
  "include": [
    "src/**/*"
  ]
}